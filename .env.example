# EODHD API key (https://eodhd.com)
EODHD_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Daily EODHD credit cap. News fetches are blocked at 80% of this value;
# all paid calls hard-stop at 100%.
EODHD_DAILY_CREDIT_CAP=20000

# SQLite path (absolute recommended in production)
DB_PATH=catalyst.db

# Universe screener thresholds
UNIVERSE_MARKET_CAP_MIN=1000000000
UNIVERSE_PRICE_MIN=10
UNIVERSE_AVG_VOL_MIN=100000

# Default per-user gap threshold (percent)
DEFAULT_GAP_THRESHOLD=5.0

# Scheduled scan time
SCAN_HOUR=11
SCAN_MINUTE=30
SCAN_TIMEZONE=Europe/Nicosia

# Optional override universe (comma-separated, e.g. AAPL.US,TSLA.US) for dry-runs.
# When set, the screener is skipped entirely.
OVERRIDE_UNIVERSE=

LOG_LEVEL=INFO
